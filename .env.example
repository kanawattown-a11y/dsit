# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dsit_tamween

# NextAuth
NEXTAUTH_SECRET=your-secret-key-min-32-chars-long-here
NEXTAUTH_URL=http://localhost:3000

# AWS S3
AWS_S3_BUCKET=dsit-tamween-files
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=me-south-1

# QR Code Encryption (32-byte hex key)
QR_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Web Push (VAPID keys - generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@dsit.gov.sy
